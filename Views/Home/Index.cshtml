<!-- ============================================================
     COMPARISON
     ============================================================ -->
<section class="comparison" id="comparison">
    <div class="container">
        <div class="comparison-header" data-aos="fade-up">
            <div class="section-label">WHY WE'RE DIFFERENT</div>
            <h2 class="section-title">Why We're Different</h2>
            <p>AI tools generate resumes. We deliver recruiter-ready career assets built with real HR judgment, narrative clarity, and positioning.</p>
        </div>

        <div class="comparison-grid">
            <div class="comp-side" data-aos="fade-right" data-aos-delay="100">
                <div class="tag" style="margin-bottom:12px;">AI RESUME TOOLS</div>
                <h3>Fast output. Low differentiation.</h3>
                <p class="sub">Template-driven output with no human context.</p>
                <ul class="comp-list">
                    <li><span class="icon">✗</span> Template-driven wording</li>
                    <li><span class="icon">✗</span> No recruiter judgment</li>
                    <li><span class="icon">✗</span> ATS-only optimisation</li>
                    <li><span class="icon">✗</span> Generic bullet points</li>
                </ul>
            </div>

            <div class="vs-pill" data-aos="zoom-in" data-aos-delay="300">VS</div>

            <div class="comp-side human" data-aos="fade-left" data-aos-delay="200">
                <div class="tag" style="margin-bottom:12px;">HUMAN-LED</div>
                <h3>HR review. Built for callbacks.</h3>
                <p class="sub">Crafted with judgment, strategy, and storytelling.</p>
                <ul class="comp-list">
                    <li><span class="icon">✓</span> Written &amp; reviewed by HR professionals</li>
                    <li><span class="icon">✓</span> Storytelling + recruiter positioning</li>
                    <li><span class="icon">✓</span> Designed for interview outcomes</li>
                    <li><span class="icon">✓</span> Unlimited revisions included</li>
                </ul>
            </div>
        </div>

        <div class="comparison-cta">
            <a href="/Assessment" class="btn btn-primary">Start Assessment</a>
        </div>
    </div>
</section>

<!-- ============================================================
     PROCESS
     ============================================================ -->
<section class="process" id="process">
    <div class="container">
        <div class="process-header" data-aos="fade-up">
            <div class="section-label">HOW WE WORK</div>
            <h2 class="section-title">Our Process</h2>
            <p>Simple, guided, human-reviewed — from assessment to final delivery.</p>
        </div>

        <div class="process-steps">
            <div class="step-card" data-aos="fade-up" data-aos-delay="100">
                <div class="step-card-img" style="background:linear-gradient(135deg,#1a180a,#2a2410);display:flex;align-items:center;justify-content:center;color:#eab308;">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 48px; height: 48px;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Zm3.75 11.625a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                    </svg>
                </div>
                <div class="step-card-body">
                    <div class="step-num">STEP 1 · Assessment</div>
                    <h3>Assessment</h3>
                    <p>Answer a short questionnaire about your career goals.</p>
                </div>
            </div>
            <div class="step-card" data-aos="fade-up" data-aos-delay="200">
                <div class="step-card-img" style="background:linear-gradient(135deg,#0a1018,#141828);display:flex;align-items:center;justify-content:center;color:#60a5fa;">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 48px; height: 48px;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.82 1.608-2.015a2.539 2.539 0 0 0 2.067-1.42 2.54 2.54 0 0 0-.256-2.58A2.538 2.538 0 0 0 15.65 10H8.35a2.538 2.538 0 0 0-2.019 1.792 2.54 2.54 0 0 0-.256 2.58 2.539 2.539 0 0 0 2.067 1.42c.95.195 1.608 1.032 1.608 2.015V18m-4.5 0h9" />
                    </svg>
                </div>
                <div class="step-card-body">
                    <div class="step-num">STEP 2 · Recommendation</div>
                    <h3>Recommendation</h3>
                    <p>We suggest the best package based on recruiter logic.</p>
                </div>
            </div>
            <div class="step-card" data-aos="fade-up" data-aos-delay="300">
                <div class="step-card-img" style="background:linear-gradient(135deg,#100a18,#1a1428);display:flex;align-items:center;justify-content:center;color:#a78bfa;">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 48px; height: 48px;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
                    </svg>
                </div>
                <div class="step-card-body">
                    <div class="step-num">STEP 3 · Intake</div>
                    <h3>Intake</h3>
                    <p>Upload resume or fill structured inputs securely.</p>
                </div>
            </div>
            <div class="step-card" data-aos="fade-up" data-aos-delay="400">
                <div class="step-card-img" style="background:linear-gradient(135deg,#0a1808,#141f10);display:flex;align-items:center;justify-content:center;color:#4ade80;">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 48px; height: 48px;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                    </svg>
                </div>
                <div class="step-card-body">
                    <div class="step-num">STEP 4 · HR Delivery</div>
                    <h3>HR Delivery</h3>
                    <p>We write, review, deliver — revisions included.</p>
                </div>
            </div>
        </div>

        <p class="process-help">Got any questions? <a href="/#contact">Talk to us</a></p>
    </div>
</section>

