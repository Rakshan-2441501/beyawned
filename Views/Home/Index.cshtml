<section class="faq-section" id="faq">
    <div class="container">
        <div class="faq-header" data-aos="fade-up">
            <div class="section-label">FAQ</div>
            <h2 class="section-title">Frequently Asked<br /><span style="color:#888">Questions</span></h2>
            <p>Everything you need to know about how Beyawned works — process, privacy, revisions, delivery, and what you get.</p>
        </div>

        <div class="faq-contact-bar">
            <div style="display:flex;gap:40px;flex-wrap:wrap;">
                <div class="faq-contact-item">
                    <h4>E-MAIL</h4>
                    <p>hello@beyawned.com</p>
                </div>
                <div class="faq-contact-item">
                    <h4>RESPONSE TIME</h4>
                    <p>Within a few hours</p>
                </div>
            </div>
            <div>
                <a href="/#contact" class="btn btn-outline btn-sm">Get in touch</a>
            </div>
        </div>

        <div class="faq-trust" style="margin-bottom:32px;justify-content:center;display:flex;gap:20px;flex-wrap:wrap;">
            <span class="faq-trust-pill">Privacy first — your data is always secure.</span>
            <span class="faq-trust-pill">Direct access to senior HR professionals.</span>
            <span class="faq-trust-pill">Human-led guidance, no automated bots.</span>
        </div>

        <div class="faq-list">
            <div class="faq-item">
                <button class="faq-question" type="button">Is Beyawned an AI resume builder?<span class="faq-icon">+</span></button>
                <div class="faq-answer"><div class="faq-answer-inner">No. Beyawned is a 100% human-led service. Every resume, CV, and LinkedIn profile is written and reviewed by experienced HR professionals and recruiters — not generated by AI templates.</div></div>
            </div>
            <div class="faq-item">
                <button class="faq-question" type="button">Are revisions really unlimited?<span class="faq-icon">+</span></button>
                <div class="faq-answer"><div class="faq-answer-inner">Yes. We don't cap revisions. We keep working with you until you're satisfied the document accurately represents your experience and is positioned for the role you're targeting.</div></div>
            </div>
            <div class="faq-item">
                <button class="faq-question" type="button">What if I don't have a resume yet?<span class="faq-icon">+</span></button>
                <div class="faq-answer"><div class="faq-answer-inner">No problem at all. Our "New" plans are designed for people starting from scratch. You'll fill out a structured intake form and we'll build your document from the ground up.</div></div>
            </div>
            <div class="faq-item">
                <button class="faq-question" type="button">How long does delivery take?<span class="faq-icon">+</span></button>
                <div class="faq-answer"><div class="faq-answer-inner">Standard delivery is 3–5 business days. Express options may be available — reach out via the contact form to discuss timelines.</div></div>
            </div>
            <div class="faq-item">
                <button class="faq-question" type="button">Is my information kept confidential?<span class="faq-icon">+</span></button>
                <div class="faq-answer"><div class="faq-answer-inner">Absolutely. Your data is handled securely and never shared with third parties. We take privacy seriously. Read our Privacy Policy for full details.</div></div>
            </div>
            <div class="faq-item">
                <button class="faq-question" type="button">What formats do you deliver in?<span class="faq-icon">+</span></button>
                <div class="faq-answer"><div class="faq-answer-inner">We deliver in both PDF and editable Word (.docx) format so you have full control over your documents.</div></div>
            </div>
        </div>
    </div>
</section>

<!-- ============================================================
     CONTACT
     ============================================================ -->
<section class="contact-section" id="contact">
    <div class="container">
        <div class="contact-grid">
            <div class="contact-side" data-aos="fade-right">
                <div class="section-label">WE'RE HERE TO HELP YOU</div>
                <h2>Discuss Your<br /><span style="color:#c8a96e">Career Questions</span></h2>
                <p>Are you looking for top-quality career services tailored to your needs? Reach out to us.</p>
            </div>

            <div class="contact-form-wrap" data-aos="fade-left" data-aos-delay="200">
                @if (TempData["ContactSuccess"] != null)
                {
                    <div class="alert alert-success">@TempData["ContactSuccess"]</div>
                }

                <form asp-action="Index" asp-controller="Home" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label asp-for="Name">Name</label>
                        <input asp-for="Name" placeholder="Your full name" />
                        <span asp-validation-for="Name" style="color:#f44336;font-size:.8rem;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Email">Email</label>
                        <input asp-for="Email" type="email" placeholder="your@email.com" />
                        <span asp-validation-for="Email" style="color:#f44336;font-size:.8rem;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Industry">Industry</label>
                        <select asp-for="Industry">
                            <option value="">Select your industry</option>
                            <option>Technology</option>
                            <option>Finance &amp; Banking</option>
                            <option>Healthcare</option>
                            <option>Marketing &amp; Creative</option>
                            <option>Engineering</option>
                            <option>Education &amp; Academia</option>
                            <option>Operations &amp; Logistics</option>
                            <option>Other</option>
                        </select>
                        <span asp-validation-for="Industry" style="color:#f44336;font-size:.8rem;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Message">Message</label>
                        <textarea asp-for="Message" placeholder="Tell us about what you need..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width:100%;">Get a Solution</button>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- ============================================================
     CTA BANNER
     ============================================================ -->
<section class="cta-banner" data-aos="zoom-in">
    <div class="container" style="position:relative;z-index:1;">
        <div class="section-label" style="text-align:center;margin-bottom:8px;">GET STARTED</div>
        <h2>Take a quick assessment to see what your resume needs — clarity, impact, ATS keywords, or structure.</h2>
        <p>Human-led • Recruiter-ready • Unlimited revisions</p>
        <a href="/Assessment" class="btn btn-accent" style="padding:14px 32px;font-size:1rem;">Get Started</a>
        <div class="cta-banner-pills">
            <span class="cta-pill">Human-led</span>
            <span class="cta-pill">Recruiter-ready</span>
            <span class="cta-pill">Unlimited revisions</span>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Scroll to contact if redirected with anchor
        if (window.location.search.includes('anchor=contact')) {
            document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth' });
        }
    </script>
}
