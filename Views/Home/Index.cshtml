@model Beyawned.Models.ContactViewModel
@{
    ViewData["Title"] = "ATS Doesn't Hire You. Recruiters Do.";
}

<!-- ============================================================
     HERO
     ============================================================ -->
<section class="hero">
    <div class="container">
        <div class="hero-grid">
            <div class="hero-left" data-aos="fade-right">
                <div class="hero-eyebrow">
                    <span class="dot"></span>
                    <span style="font-size:.8rem; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:#888">Human-Led Career Services</span>
                </div>

                <h1 class="hero-title">
                    ATS<br />
                    <span style="color:#c8a96e">Doesn't Hire You.</span><br />
                    Recruiters do.
                </h1>
                <p class="hero-subtitle">
                    Get a resume + LinkedIn profile that reads like a <em>human wrote it</em>.
                    Built for real callbacks, not generic keywords.
                </p>

                <div class="hero-cta">
                    <a href="/Assessment" class="btn btn-primary">Take free assessment</a>
                    <a href="/Products" class="btn btn-outline">View products</a>
                </div>

                <label class="hero-upload" for="resumeUpload">
                    <div class="hero-upload-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 24px; height: 24px;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m6.75 12-3-3m0 0-3 3m3-3v6m-1.5-15H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                        </svg>
                    </div>
                    <div>
                        <strong>+ Add your resume here</strong>
                        <p>Drag and drop or click to upload (PDF/Word)</p>
                    </div>
                    <input type="file" id="resumeUpload" class="hero-upload-input" accept=".pdf,.doc,.docx" />
                </label>

                <div class="hero-companies" style="margin-top:32px;">
                    <span class="hero-companies-label">Our customers get hired at</span>
                    <div class="hero-companies-logos">
                        <span>Meta</span>
                        <span>Apple</span>
                        <span>Amazon</span>
                        <span>Netflix</span>
                        <span>Google</span>
                        <span>Booking.com</span>
                    </div>
                </div>
            </div>

            <!-- right column preview card -->
            <div class="hero-right" data-aos="fade-left" data-aos-delay="200">
                <div class="hero-preview-card">
                    <div style="background:linear-gradient(135deg,#1a1a1a,#222);padding:48px 32px; text-align:center;">
                        <div style="background:#2a2a2a;border:1px solid #333;border-radius:10px;padding:28px;max-width:300px;margin:0 auto;">
                            <div style="font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;color:#c8a96e;margin-bottom:10px;">Executive Style</div>
                            <div style="font-size:1.2rem;font-weight:800;margin-bottom:6px;">Your Name</div>
                            <div style="font-size:.82rem;color:#888;margin-bottom:20px;">Senior Product Manager &#64; FAANG</div>
                            <div style="display:flex;flex-direction:column;gap:8px;">
                                <div style="height:8px;background:#2a2a2a;border-radius:4px;border:1px solid #333;"></div>
                                <div style="height:8px;background:#2a2a2a;border-radius:4px;border:1px solid #333;width:80%;"></div>
                                <div style="height:8px;background:#2a2a2a;border-radius:4px;border:1px solid #333;width:60%;"></div>
                            </div>
                        </div>
                        <p style="font-size:.78rem;color:#555;margin-top:20px;">Mechanically sound · Humanly perfect!</p>
                    </div>
                </div>
                <div class="hero-badge">
                    <strong>6 sec</strong>average recruiter read time
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============================================================
     WHY US
     ============================================================ -->
<section class="why-us" id="why-us">
    <div class="container">
        <div class="why-us-header" data-aos="fade-up">
            <div class="section-label">WHY US?</div>
            <h2 class="section-title">
                Your resume isn't<br />the problem.<br />
                <span style="color:#888;">How it's built is.</span>
            </h2>
            <p style="color:#888;margin-top:16px;max-width:540px;margin-left:auto;margin-right:auto;line-height:1.7;">
                The difference is judgment. Your assets are crafted by people who understand how recruiters decide.
            </p>
            <div style="display:flex;gap:12px;justify-content:center;margin-top:24px;flex-wrap:wrap;">
                <a href="/Assessment" class="btn btn-primary">Take free assessment</a>
                <a href="/Products" class="btn btn-outline">View products</a>
            </div>
        </div>

        <div class="why-us-grid">
            <div class="why-card" data-aos="fade-up" data-aos-delay="100">
                <div class="why-card-num">01</div>
                <h3>Built by people who've made hiring decisions</h3>
                <p>We understand recruiter psychology. Our team has sat on the other side of the table. We know what makes a hiring manager stop scrolling and start caring.</p>
            </div>
            <div class="why-card" data-aos="fade-up" data-aos-delay="200">
                <div class="why-card-num">02</div>
                <h3>32-point Quality Check</h3>
                <p>Before anything leaves our team, it passes a non-negotiable HR verification process. If it doesn't meet the standard, it doesn't get delivered.</p>
            </div>
            <div class="why-card" data-aos="fade-up" data-aos-delay="300">
                <div class="why-card-num">03</div>
                <h3>We don't fix resumes. We rebuild careers on paper.</h3>
                <p>Most services reformat what you give them. We extract what you've never been able to say and turn it into a document that opens doors.</p>
            </div>
            <div class="why-card" data-aos="fade-up" data-aos-delay="400">
                <div class="why-card-num">04</div>
                <h3>Built for the role you want, not the one you have.</h3>
                <p>We don't summarize your past. We reverse-engineer your career story to position you for the exact role and industry you're targeting.</p>
            </div>
            <div class="why-card" data-aos="fade-up" data-aos-delay="500">
                <div class="why-card-num">05</div>
                <h3>Impact you didn't know you had.</h3>
                <p>"I don't have any achievements to show" is what most people say. We extract measurable proof from any experience. We investigate, not fabricate.</p>
            </div>
            <div class="why-card" data-aos="fade-up" data-aos-delay="600">
                <div class="why-card-num">06</div>
                <h3>Designed for how recruiters actually decide.</h3>
                <p>Resumes get 6 seconds. LinkedIn profiles get 30. Cover letters get skimmed. We engineer every element for how hiring decisions are really made.</p>
            </div>
        </div>
    </div>
</section>

<!-- ============================================================
