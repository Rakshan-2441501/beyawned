@{
    ViewData["Title"] = "Products – Career Services";
}

<section class="products-page">
    <div class="container">
        <div class="products-page-header">
            <div class="section-label">OUR PRODUCTS</div>
            <h1 class="section-title">Choose what you need.</h1>
            <p style="color:#888;max-width:540px;margin:14px auto 0;line-height:1.7;">
                Every plan includes professional HR review, recruiter-led strategy, and unlimited revisions.
            </p>
        </div>

        <div class="products-page-grid">

            <!-- CV Writing -->
            <div class="product-page-card" id="cv">
                <span class="tag">CV</span>
                <h2>CV Writing</h2>
                <p>Detailed, structured CV for academic, research, and international applications. Ideal for roles that require depth and precision.</p>
                <ul class="product-features" style="margin-bottom:24px;">
                    <li>Academic &amp; Research Focus</li>
                    <li>International Standards</li>
                    <li>Advanced Experience Tracking</li>
                    <li>Unlimited Revisions</li>
                </ul>
                <div class="price-row">
                    <h4>Select Plan</h4>
                    <div class="price-options">
                        <div class="price-opt">
                            <small>Existing CV</small>
                            <strong>Deep rework + positioning</strong>
                            <a href="/Assessment?product=cv-existing" class="btn btn-outline btn-sm" style="width:100%;">Buy existing</a>
                        </div>
                        <div class="price-opt">
                            <small>New CV</small>
                            <strong>Build from scratch</strong>
                            <a href="/Assessment?product=cv-new" class="btn btn-primary btn-sm" style="width:100%;">Buy new</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Resume Writing -->
            <div class="product-page-card" id="resume">
                <span class="tag">RESUME</span>
                <h2>Resume Writing</h2>
                <p>Recruiter-grade, role-specific resume built for callbacks and clarity. Engineered to win the 6-second scan.</p>
                <ul class="product-features" style="margin-bottom:24px;">
                    <li>ATS-Optimized Architecture</li>
                    <li>Action-Oriented Narrative</li>
                    <li>6-Second Rule Alignment</li>
                    <li>Unlimited Revisions</li>
                </ul>
                <div class="price-row">
                    <h4>Select Plan</h4>
                    <div class="price-options">
                        <div class="price-opt">
                            <small>Existing Resume</small>
                            <strong>Deep rework + positioning</strong>
                            <a href="/Assessment?product=resume-existing" class="btn btn-outline btn-sm" style="width:100%;">Buy existing</a>
                        </div>
                        <div class="price-opt">
                            <small>New Resume</small>
                            <strong>Build from scratch</strong>
                            <a href="/Assessment?product=resume-new" class="btn btn-primary btn-sm" style="width:100%;">Buy new</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- LinkedIn -->
            <div class="product-page-card" id="linkedin">
                <span class="tag">LINKEDIN</span>
                <h2>Profile Optimization</h2>
                <p>Turn your LinkedIn into a recruiter magnet with strong positioning, narrative headline, and smart keyword integration.</p>
                <ul class="product-features" style="margin-bottom:24px;">
                    <li>SEO-Optimized Headline</li>
                    <li>Narrative-driven Summary</li>
                    <li>Strategic Keyword Integration</li>
                    <li>Premium plan includes full setup</li>
                </ul>
                <div class="price-row">
                    <h4>Select Plan</h4>
                    <div class="price-options">
                        <div class="price-opt">
                            <small>Beginner</small>
                            <strong>Headline + Summary</strong>
                            <a href="/Assessment?product=linkedin-beginner" class="btn btn-outline btn-sm" style="width:100%;">Beginner</a>
                        </div>
                        <div class="price-opt">
                            <small>Pro</small>
                            <strong>Full profile setup</strong>
                            <a href="/Assessment?product=linkedin-pro" class="btn btn-primary btn-sm" style="width:100%;">Pro</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Student Bundle -->
            <div class="product-page-card" id="student">
                <span class="tag">STUDENTS</span>
                <h2>Student Bundle</h2>
                <p>Resume + LinkedIn, crafted from projects, academics, internships, and skills. Perfect for entry-level and early career.</p>
                <ul class="product-features" style="margin-bottom:24px;">
                    <li>Internship-focused Layout</li>
                    <li>Academic Excellence Setup</li>
                    <li>Full CV + LinkedIn Bundle</li>
                    <li>Premium plan includes full setup</li>
                </ul>
                <div class="price-row">
                    <a href="/Assessment?product=student" class="btn btn-primary" style="width:100%;">Buy now →</a>
                </div>
            </div>

            <!-- Cover Letters -->
            <div class="product-page-card">
                <span class="tag">ADD-ON</span>
                <h2>Cover Letters</h2>
                <p>Compelling, role-specific cover letters that complement your resume with a strong narrative and personal voice.</p>
                <ul class="product-features" style="margin-bottom:24px;">
                    <li>Role-Specific Customization</li>
                    <li>Narrative-first Structure</li>
                    <li>Matches Your Resume Style</li>
                </ul>
                <div class="price-row">
                    <a href="/Assessment?product=cover-letter" class="btn btn-primary" style="width:100%;">Get started →</a>
                </div>
            </div>

            <!-- SOP Writing -->
            <div class="product-page-card">
                <span class="tag">ADD-ON</span>
                <h2>SOP Writing</h2>
                <p>Statement of Purpose crafted for grad school and scholarship applications — structured, compelling, and authentic.</p>
                <ul class="product-features" style="margin-bottom:24px;">
                    <li>Program-Specific Framing</li>
                    <li>Authentic Voice Preservation</li>
                    <li>Admission-Ready Structure</li>
                </ul>
                <div class="price-row">
                    <a href="/Assessment?product=sop" class="btn btn-primary" style="width:100%;">Get started →</a>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta-banner">
    <div class="container" style="position:relative;z-index:1;">
        <h2>Not sure which product is right for you?</h2>
        <p>Take our free 2-minute assessment and we'll recommend the best package for your goals.</p>
        <a href="/Assessment" class="btn btn-accent" style="padding:14px 32px;font-size:1rem;">Take free assessment</a>
    </div>
</section>
