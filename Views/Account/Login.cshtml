@model Beyawned.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="login-page">
    <div class="login-card">
        <a href="/" class="navbar-brand" style="display:block;margin-bottom:28px;">Bey<span>awned</span></a>
        <h1>Welcome back</h1>
        <p class="sub">Log in to your Beyawned account to track your order or access deliverables.</p>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form asp-action="ExternalLogin" asp-controller="Account" method="post" style="margin-bottom:24px;">
            <input type="hidden" name="provider" value="Google" />
            <button type="submit" class="btn btn-outline" style="width:100%;padding:14px;justify-content:center;">
                <svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
                    <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/>
                </svg>
                Continue with Google
            </button>
        </form>

        <div class="divider">or continue with email</div>

        <form asp-action="Login" asp-controller="Account" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email" placeholder="your@email.com" autocomplete="email" />
                <span asp-validation-for="Email" style="color:#f44336;font-size:.8rem;"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Password" style="color:#f44336;font-size:.8rem;"></span>
            </div>

            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
                <label style="display:flex;align-items:center;gap:8px;font-size:.88rem;color:#888;cursor:pointer;">
                    <input asp-for="RememberMe" type="checkbox" style="accent-color:#c8a96e;" />
                    Remember me
                </label>
                <a href="#" style="font-size:.85rem;color:#c8a96e;">Forgot password?</a>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%;padding:14px;">Sign In</button>
        </form>

        <p class="login-link">
            Don't have an account yet?
            <a href="/Assessment">Take the assessment →</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
