@{
    ViewData["Title"] = "Privacy Policy";
}
<section style="padding:120px 0 80px;">
    <div class="container" style="max-width:760px;">
        <div class="section-label">LEGAL</div>
        <h1 class="section-title" style="margin-bottom:32px;">Privacy Policy</h1>
        <div style="color:#888;line-height:1.9;font-size:.95rem;">
            <p style="margin-bottom:20px;">Your privacy is important to us. This policy explains what data we collect and how we use it.</p>
            <h3 style="color:#fff;font-size:1.05rem;margin:28px 0 10px;">Data We Collect</h3>
            <p>We collect information you provide directly: name, email address, career history, and documents you upload. We also collect basic usage analytics (pages visited, session duration) to improve our service.</p>
            <h3 style="color:#fff;font-size:1.05rem;margin:28px 0 10px;">How We Use Your Data</h3>
            <p>Your data is used solely to deliver the service you've purchased, communicate with you about your order, and improve our offerings. We do not sell your data.</p>
            <h3 style="color:#fff;font-size:1.05rem;margin:28px 0 10px;">Data Retention</h3>
            <p>We retain your intake data and documents for 12 months to facilitate revisions. After that period, data is deleted unless you request earlier removal.</p>
            <h3 style="color:#fff;font-size:1.05rem;margin:28px 0 10px;">Your Rights</h3>
            <p>You may request access to, correction of, or deletion of your personal data at any time by emailing hello@beyawned.com.</p>
            <p style="margin-top:32px;color:#555;">Last updated: February 2026</p>
        </div>
    </div>
</section>
