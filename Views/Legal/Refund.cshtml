@{
    ViewData["Title"] = "Refund Policy";
}
<section style="padding:120px 0 80px;">
    <div class="container" style="max-width:760px;">
        <div class="section-label">LEGAL</div>
        <h1 class="section-title" style="margin-bottom:32px;">Refund Policy</h1>
        <div style="color:#888;line-height:1.9;font-size:.95rem;">
            <p style="margin-bottom:20px;">We stand behind our work. If you're not satisfied, here's how we handle refunds.</p>
            <h3 style="color:#fff;font-size:1.05rem;margin:28px 0 10px;">Unlimited Revisions First</h3>
            <p>Before requesting a refund, we strongly encourage you to use our unlimited revisions policy. Our team will rework any element of your document until it meets your expectations.</p>
            <h3 style="color:#fff;font-size:1.05rem;margin:28px 0 10px;">Refund Eligibility</h3>
            <p>Refund requests may be considered in cases where: (1) we failed to deliver within the agreed timeline without prior notice, or (2) the delivered document is factually incorrect based on the information you provided and we're unable to correct it through revision.</p>
            <h3 style="color:#fff;font-size:1.05rem;margin:28px 0 10px;">Non-Refundable Situations</h3>
            <p>Refunds are not available after unlimited revision attempts have been exhausted, or where the client has changed the job target or career direction mid-engagement.</p>
            <h3 style="color:#fff;font-size:1.05rem;margin:28px 0 10px;">How to Request</h3>
            <p>Email hello@beyawned.com with your order details and reason for refund. We respond within 24 hours.</p>
            <p style="margin-top:32px;color:#555;">Last updated: February 2026</p>
        </div>
    </div>
</section>
