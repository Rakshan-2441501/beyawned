@{
    ViewData["Title"] = "Delivery & Revision Policy";
}
<section style="padding:120px 0 80px;">
    <div class="container" style="max-width:760px;">
        <div class="section-label">LEGAL</div>
        <h1 class="section-title" style="margin-bottom:32px;">Delivery &amp; Revision Policy</h1>
        <div style="color:#888;line-height:1.9;font-size:.95rem;">
            <h3 style="color:#fff;font-size:1.05rem;margin:0 0 10px;">Delivery Timelines</h3>
            <ul style="margin-left:20px;margin-bottom:20px;">
                <li style="margin-bottom:8px;list-style:disc;">Resume / CV (existing): 3–5 business days</li>
                <li style="margin-bottom:8px;list-style:disc;">Resume / CV (new): 4–6 business days</li>
                <li style="margin-bottom:8px;list-style:disc;">LinkedIn Profile Optimization: 2–4 business days</li>
                <li style="margin-bottom:8px;list-style:disc;">Student Bundle: 4–6 business days</li>
                <li style="margin-bottom:8px;list-style:disc;">Cover Letter: 2–3 business days</li>
            </ul>
            <p>Timelines begin after intake form completion and all required information is received.</p>
            <h3 style="color:#fff;font-size:1.05rem;margin:28px 0 10px;">Revisions</h3>
            <p>All plans include unlimited revisions. We iterate until you're satisfied. Revision requests should be submitted via email with clear, specific feedback.</p>
            <h3 style="color:#fff;font-size:1.05rem;margin:28px 0 10px;">Delivery Format</h3>
            <p>All documents are delivered in PDF and editable Word (.docx) format via email.</p>
            <h3 style="color:#fff;font-size:1.05rem;margin:28px 0 10px;">Delays</h3>
            <p>In cases where delivery may be delayed, we will notify you proactively via email with an updated timeline.</p>
            <p style="margin-top:32px;color:#555;">Last updated: February 2026</p>
        </div>
    </div>
</section>
